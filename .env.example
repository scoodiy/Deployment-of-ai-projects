# Admin backend environment variables
# Copy to .env and fill in real values

# JWT secret for admin auth (REQUIRED in production)
JWT_SECRET=your-random-secret-here

# Admin credentials for first-time initialization
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Node environment
NODE_ENV=production

# Stock analysis integration
# Next.js calls this local Python service from the server side only.
DAILY_STOCK_API_URL=http://127.0.0.1:8000

# daily_stock_analysis runtime examples. Put real keys only in .env.
STOCK_LIST=600519,hk00700,AAPL
LITELLM_MODEL=deepseek/deepseek-v4-flash
AGENT_LITELLM_MODEL=deepseek/deepseek-v4-flash
DEEPSEEK_API_KEY=your-deepseek-key-here
