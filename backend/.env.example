# Stock-AYUU 后端环境变量配置
# 复制为 .env 并填写实际值

# 数据库 - 完整连接 URL (优先使用)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stock_db

# 数据库 - 单独参数 (DATABASE_URL 为空时使用)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=stock_db

# 应用配置
APP_NAME=Stock-AYUU
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false

# 后端端口
BACKEND_PORT=9988

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=https://ayuu.fun,http://localhost:5173,http://localhost:9988

# 数据刷新令牌（保护 /api/data/refresh 端点）
REFRESH_TOKEN=your-refresh-token-here

# LLM 配置（可选，用于 AI 问答功能）
# LLM_API_KEY=sk-your-key
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini
